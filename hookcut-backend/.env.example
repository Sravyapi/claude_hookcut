# HookCut Backend — Environment Variables
# Copy this to .env and fill in your values.

# Core
DATABASE_URL=postgresql://postgres:password@localhost:5432/hookcut
REDIS_URL=redis://localhost:6379/0
FRONTEND_URL=http://localhost:3000

# LLM — at least one provider key is required
LLM_PRIMARY_PROVIDER=gemini
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
GEMINI_API_KEY=your-gemini-api-key
WHISPER_API_KEY=

# Auth (NextAuth.js)
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars
NEXTAUTH_URL=http://localhost:3000

# Feature Flags
FEATURE_V0_MODE=false
FEATURE_WHISPER_FALLBACK=true
FEATURE_R2_STORAGE=false

# Payments
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=...
RAZORPAY_PLAN_ID_LITE=plan_...
RAZORPAY_PLAN_ID_PRO=plan_...

# Storage (Cloudflare R2 — optional, local storage used by default)
# R2_ACCOUNT_ID=...
# R2_ACCESS_KEY_ID=...
# R2_SECRET_ACCESS_KEY=...
# R2_BUCKET_NAME=hookcut-shorts
# R2_PUBLIC_URL=https://...

# Monitoring
SENTRY_DSN=
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# Operational
TEMP_FILE_TTL_HOURS=24
