# HookCut Production Environment Variables
# Copy this to your deployment platform's env var settings.

# ─── Backend (Railway) ───────────────────────────────────────────────────────

# Auto-set by Railway plugins:
# DATABASE_URL=postgresql://...  (Railway Postgres plugin)
# REDIS_URL=redis://...          (Railway Redis plugin)

# Must set manually:
FRONTEND_URL=https://hookcut.nyxpath.com
FEATURE_V0_MODE=true

# Auth (must match Vercel's NEXTAUTH_SECRET)
NEXTAUTH_SECRET=generate-a-32-char-secret-here
NEXTAUTH_URL=https://hookcut.nyxpath.com

# LLM — at least one required
LLM_PRIMARY_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=

# Payments (set when ready)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Storage (set when ready for R2)
FEATURE_R2_STORAGE=false
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=hookcut-shorts
R2_PUBLIC_URL=

# Monitoring (set when ready)
SENTRY_DSN=
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# ─── Frontend (Vercel) ───────────────────────────────────────────────────────

NEXT_PUBLIC_API_URL=https://api.hookcut.nyxpath.com/api
# NEXTAUTH_URL=https://hookcut.nyxpath.com          (same as backend)
# NEXTAUTH_SECRET=...                                (same as backend)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── DNS Records (Hostinger) ─────────────────────────────────────────────────
# TYPE    NAME              VALUE
# CNAME   hookcut           cname.vercel-dns.com
# CNAME   api.hookcut       <your-railway-domain>.up.railway.app
